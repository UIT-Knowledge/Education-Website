# Auto-detect text files and normalize line endings
* text=auto

# Source code - normalize to LF
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.md text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf

# Binary files - do not touch
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
